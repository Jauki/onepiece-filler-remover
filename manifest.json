{
  "manifest_version": 3,
  "name": "One Piece Filler Filter",
  "version": "1.0.0",
  "permissions": ["storage"],
  "host_permissions": [
    "https://aniworld.to/*",
    "https://www.animefillerlist.com/*"
  ],
  "browser_specific_settings": {
  "gecko": {
    "id": "jauk.j@proton.me",
    "strict_min_version": "109.0"
  }
},
  "background": {
    "service_worker": "src/background/index.ts",
    "scripts": ["src/background/index.ts"]
  },
  "content_scripts": [{
    "matches": ["https://aniworld.to/*"],
    "js": ["src/content/index.ts"]
  }]
}